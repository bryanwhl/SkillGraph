{
  "name": "skillgraph",
  "version": "0.2.0",
  "description": "SkillGraph is a runtime layer for AI agents that turns flat skill libraries into graph-structured, progressively disclosed capability context.",
  "type": "module",
  "bin": {
    "skillgraph": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "scripts",
    "agent-skill",
    "docs",
    "examples",
    "README.md",
    "LICENSE",
    "PRD.md",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ],
  "directories": {
    "doc": "docs",
    "example": "examples"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo": "npm run build && node scripts/demo.mjs",
    "dev": "tsx src/cli/index.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bryanwhl/SkillGraph.git"
  },
  "bugs": {
    "url": "https://github.com/bryanwhl/SkillGraph/issues"
  },
  "homepage": "https://github.com/bryanwhl/SkillGraph#readme",
  "keywords": [
    "agent-skills",
    "skills",
    "cli",
    "graph",
    "codex",
    "claude"
  ],
  "author": "bryanwhl",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.2.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
